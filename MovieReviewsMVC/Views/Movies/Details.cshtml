@model MovieReviewsMVC.Models.Movie

@{
    ViewData["Title"] = Model.Title;
}

<div class="container mt-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">← Назад к списку</a></li>
        </ol>
    </nav>

    <div class="card">
        <div class="card-header bg-primary text-white">
            <h2>@Model.Title</h2>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6">
                    <table class="table table-bordered">
                        <tr>
                            <th style="width: 30%">Жанр</th>
                            <td>@Model.Genre</td>
                        </tr>
                        <tr>
                            <th>Год выпуска</th>
                            <td>@Model.Year</td>
                        </tr>
                        <tr>
                            <th>Рейтинг</th>
                            <td>
                                <span class="badge bg-warning text-dark fs-6">⭐ @Model.Rating.ToString("0.0")</span>
                            </td>
                        </tr>
                        @if (!string.IsNullOrEmpty(Model.Director))
                        {
                            <tr>
                                <th>Режиссер</th>
                                <td>@Model.Director</td>
                            </tr>
                        }
                    </table>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(Model.Description))
            {
                <div class="mt-3">
                    <h5>Описание</h5>
                    <p>@Model.Description</p>
                </div>
            }
        </div>
    </div>
</div>