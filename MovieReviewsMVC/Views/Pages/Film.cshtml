@{
    ViewData["Title"] = "Дивергент - все о фильме, кадры из фильма, интересные факты. ПОЗНАНИЕ";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="/css/film.css" />
}

<!-- MAIN -->
<main class="main-content">
    <div class="gallery-block">
        <p class="gallery-title">Фото из фильма</p>
        <div class="gallery-container">
            <div class="gallery-item">
                <img src="/img/дивергент_фото1.jpg" onerror="this.src='/img/placeholder.png';" alt="Дивергент" />
            </div>
            <div class="gallery-item">
                <img src="/img/дивергент_фото2.jpg" onerror="this.src='/img/placeholder.png';" alt="Дивергент" />
            </div>
            <div class="gallery-item">
                <img src="/img/дивергент_фото3.jpg" onerror="this.src='/img/placeholder.png';" alt="Дивергент" />
            </div>
            <div class="gallery-item">
                <img src="/img/дивергент_фото4.jpg" onerror="this.src='/img/placeholder.png';" alt="Дивергент" />
            </div>
            <div class="gallery-item hidden-photo">
                <img src="/img/дивергент_фото5.jpg" onerror="this.src='/img/placeholder.png';" alt="Дивергент" />
            </div>
            <div class="gallery-item hidden-photo">
                <img src="/img/дивергент_фото6.jpg" onerror="this.src='/img/placeholder.png';" alt="Дивергент" />
            </div>
            <div class="gallery-item hidden-photo">
                <img src="/img/дивергент_фото7.jpg" onerror="this.src='/img/placeholder.png';" alt="Дивергент" />
            </div>
            <div class="gallery-item hidden-photo">
                <img src="/img/дивергент_фото8.jpg" onerror="this.src='/img/placeholder.png';" alt="Дивергент" />
            </div>
            <div class="gallery-item hidden-photo">
                <img src="/img/дивергент_фото9.jpeg" onerror="this.src='/img/placeholder.png';" alt="Дивергент" />
            </div>
        </div>
        <button class="load-more-photos-btn">
            <i class="fas fa-plus"></i> Показать еще фото
        </button>
    </div>

    <div class="content-right">
        <div class="movie-block" style="background-image:url('/img/дивергент_центр.jpg');">
            <div class="movie-text">
                <h1 class="movie-title">Дивергент</h1>
                <p class="movie-description">
                    В антиутопическом Чикаго будущего общество разделено на пять фракций: «Эрудиция», «Дружелюбие», «Искренность», «Отречение» и «Бесстрашие». Каждый житель, достигший 16 лет, должен пройти тест, чтобы определить, к какой фракции он принадлежит. Юная Беатрис оказывается угрозой для всей сложившейся системы, когда тесты выявляют в ней дивергента — человека, которого невозможно однозначно определить в одну из фракций.
                </p>
                <div class="movie-info">
                    <span>Год: 2014</span>
                    <span>Жанр: Фантастика, Боевик</span>
                    <span>Рейтинг: 6.8</span>
                </div>
                <div class="movie-buttons">
                    <button class="btn">Смотреть трейлер</button>
                    <button class="btn">Детали фильма</button>
                    <button class="btn favorite-btn" title="Добавить в избранное">
                        <i class="fa-regular fa-heart"></i>
                    </button>
                </div>
            </div>
        </div>

        <div class="text-section">
            <h2>Фильм «Дивергент» (2014): Актеры, съемки и интересные факты о фантастическом боевике</h2>
            <p>
                Фантастический боевик «Дивергент», снятый по мотивам бестселлера Вероники Рот, переносит зрителя в постапокалиптический Чикаго. Картина Нейла Бёргера стала крупнобюджетной экранизацией, съемки которой проходили с апреля по июль 2013 года. Для создания атмосферы разрухи и забвения съемочная группа активно использовала реальные локации Чикаго. Например, знаменитое колесо обозрения — это Navy Pier Ferris Wheel, а для антуража его окружили искусственной пылью и мусором. Даже стена, ограждающая город, была создана не с нуля, а путем компьютерного размножения макета советской РЛС «Дуга». Чтобы актеры правдоподобно выглядели в роли бойцов фракции Бесстрашных, весь основной состав прошел двухмесячные тренировки в специально созданном «учебном лагере для новобранцев».
            </p>

            <div class="text-content hidden-text">
                <h2>Где снимали «Дивергент»: Локации Чикаго для фракций</h2>
                <p>Создатели фильма хотели добиться максимальной достоверности, поэтому основные съемки проходили не в голливудских павильонах, а в самом Чикаго. Павильоны студии Cinespace Chicago Film Studios стали домашней базой, но ключевые сцены снимались «в полях». Так, напряженная церемония Выбора, где герои решают свою судьбу, была снята в здании 17th Church of Christ, Scientist на площади Pioneer Court. Улицы будущего мегаполиса — это хорошо узнаваемые уголки города: 57-я улица, Ellis Avenue рядом с Университетом Чикаго, Federal Street с ее железнодорожными эстакадами и парадная Michigan Avenue. Каждая локация была тщательно переработана, чтобы погрузить зрителя в мрачный мир будущего.</p>

                <h2>Актерский состав «Дивергента»: Кастинг и неожиданные совпадения</h2>
                <p>Подбор актеров для экранизации такого масштаба всегда полон интересных поворотов. Изначально Майлз Теллер, известный по фильму «Одержимость», пробовался на роль Четыре, которая в итоге досталась Тео Джеймсу. Теллеру отказали, но спустя несколько месяцев продюсеры, впечатленные его работой в фильме «Захватывающее время» (2013), сами предложили ему роль антагониста Эрика. Теллер отказался, посчитав, что не справится, но затем ему поступило предложение сыграть другого негодяя — Питера. Актер согласился только после личного сообщения от Шейлин Вудли, с которой он уже снимался в «Захватывающем времени». Она уговорила его присоединиться к проекту, чтобы снова работать вместе. </p>

                <h2>«Дивергент» сегодня: Что стало с франшизой и ее актерами</h2>
                <p>Несмотря на то, что киносага не была завершена из-за провала третьей части («Дивергент, глава 3: За стеной»), ее наследие живо. Изначально планировался четвертый фильм, но из-за слабых кассовых сборов студия решила не рисковать. Интересно, что финальную часть хотели выпустить в формате телевизионного фильма со сменой актерского состава, но эта идея не была реализована. Однако для многих актеров «Дивергент» стал важным трамплином: Шейлин Вудли получила номинацию на «Оскар» за роль в «Одаренной», Тео Джеймс стал звездой сериала «Время приключений», а Майлз Теллер снялся в блокбастере «Топ Ган: Мэверик». Таким образом, даже незавершенная франшиза оказала значительное влияние на голливудский кинематограф, открыв миру новые таланты.</p>

                <h2>Сравнение книги и фильма «Дивергент»: Главные отличия и пропущенные сцены</h2>
                <p>Экранизация романа Вероники Рот в целом следует первоисточнику, однако создатели внесли несколько существенных изменений. Одним из самых заметных отличий стало сокращение многих внутренних монологов Трис, которые в книге помогают глубже понять ее характер и сомнения. Также в фильме полностью отсутствует сюжетная линия с матерью Четыре — важный эпизод, раскрывающий его прошлое. Сцена инициации в книге была более жестокой и продолжительной, включая дополнительные испытания, которые вырезали для сохранения хронометража. При этом визуальное воплощение симуляций страха получилось даже более эффектным, чем в литературной версии, благодаря современным спецэффектам.</p>

                <h2>Саундтрек «Дивергент»: Музыкальное сопровождение антиутопии</h2>
                <p>Музыкальная составляющая фильма стала важным элементом создания атмосферы. Саундтрек включал композиции от известных исполнителей, включая Элли Голдинг с треком «Beating Heart», который идеально передал эмоциональную глубину переживаний главной героини. Композитор Джанки XL создал оригинальную партитуру, сочетающую электронные и оркестровые аранжировки для передачи напряжения и драматизма. Особенностью саундтрека стало использование пульсирующих ритмов в сценах тренировок Бесстрашных и более лиричных мелодий в моментах сближения Трис и Четыре. Музыка не просто сопровождала действие, а стала полноценным рассказчиком, усиливая зрительское погружение в мир разделенного общества.</p>

                <h2>Неизвестные факты о съемках «Дивергента»</h2>
                <p>Создание фильма было окутано завесой тайны — съемочный процесс шел под рабочим названием «Дрозд», а подробности проекта раскрылись только после премьеры. Кастинг преподнес несколько сюрпризов: например, Джереми Ирвин отказался от роли Четыре, не желая становиться подростковым кумиром.</p>
                <p>На площадке происходило немало курьезных ситуаций. Кейт Уинслет снималась на пятом месяце беременности и постоянно прятала растущий живот за крупными аксессуарами. А создание знаменитой татуировки Тео Джеймса превратилось в трехчасовой перфоманс — художники собирали ее из 40 фрагментов как гигантский пазл, вдохновляясь советским конструктивизмом.</p>
                <p>Отношения между актерами тоже влияли на съемки: Шейлин Вудли и Майлз Теллер, будучи близкими друзьями, с трудом изображали врагов, а их драки ставили каскадеры. При этом Вудли и Энсел Элгорт, игравшие брата и сестру, всего через год предстали романтической парой в «Виноваты звезды». Чтобы придать фильму достоверности, весь актерский состав прошел восьминедельную подготовку в учебном лагере, где их тренировали как настоящих бойцов.</p>
            </div>
            <button class="read-more-btn">
                <span class="read-more-text">Читать далее</span>
                <span class="read-less-text" style="display: none;">Свернуть</span>
                <i class="fas fa-chevron-down"></i>
            </button>
        </div>
    </div>
</main>

@section Scripts {
    <script src="/js/film.js"></script>
}